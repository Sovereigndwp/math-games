{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Sovereigndwp/math-games/schemas/generation_manifest.schema.json",
  "title": "Generation Manifest",
  "description": "Package 5. The provenance record of a single generation run. Written by a generator script after it processes a generation_request. Records what was read, what was written, which schema versions were in effect, and whether generation succeeded. Manifests are append-only: once written, they should not be rewritten for the same request.",
  "type": "object",
  "required": [
    "schema_version",
    "manifest_id",
    "request_id",
    "generated_at",
    "generator_name",
    "generator_version",
    "source_artifacts",
    "output_artifacts",
    "schema_versions_used",
    "status"
  ],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "0.1.0"
    },
    "manifest_id": {
      "type": "string",
      "pattern": "^gm_[0-9]{8}_[a-z0-9]{6}$"
    },
    "request_id": {
      "type": "string",
      "pattern": "^gr_[0-9]{8}_[a-z0-9]{6}$"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "generator_name": {
      "type": "string"
    },
    "generator_version": {
      "type": "string"
    },
    "source_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "hash", "kind"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "kind": {
            "type": "string",
            "enum": ["concept_brief", "build_plan"]
          }
        }
      }
    },
    "output_artifacts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["path", "hash", "kind"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "hash": {
            "type": "string",
            "pattern": "^sha256:[a-f0-9]{64}$"
          },
          "kind": {
            "type": "string",
            "enum": ["concept_packet_draft"]
          }
        }
      }
    },
    "schema_versions_used": {
      "type": "object",
      "required": ["generation_request_schema", "generation_manifest_schema"],
      "additionalProperties": false,
      "properties": {
        "generation_request_schema": {"type": "string"},
        "generation_manifest_schema": {"type": "string"},
        "concept_brief_schema": {"type": ["string", "null"]},
        "build_plan_schema": {"type": ["string", "null"]}
      }
    },
    "status": {
      "type": "string",
      "enum": ["success", "failure"]
    },
    "notes": {
      "type": ["string", "null"],
      "maxLength": 1000
    }
  }
}
